# RENOMEIE para secrets.toml e preencha com seus dados reais.
# NUNCA suba o secrets.toml real para o GitHub (já está no .gitignore).

[smtp]
host = "smtp.gmail.com"
port = 587
user = "chromisweb@gmail.com"
# Senha de app do Gmail (NÃO é a senha normal):
# crie em https://myaccount.google.com/apppasswords
app_password = "xxxx xxxx xxxx xxxx"

[google_oauth]
# Opcional — para login com Google.
# Crie em https://console.cloud.google.com/apis/credentials
client_id = "seu-client-id.apps.googleusercontent.com"
client_secret = "seu-client-secret"
redirect_uri = "https://seu-app.streamlit.app"
